<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>First Mate Supplier Invitation</title>
</head>
<body style="margin:0; padding:30px 0; background-color:#f2f4f6; font-family:Arial, sans-serif; color:#000000;">
  <div style="max-width:600px; margin:0 auto;">
    <table style="width:100%; border-collapse:collapse; background-color:#ffffff;">
      <tr>
        <td style="background-color:#003760; padding:24px; text-align:center;">
          <img src="{{image_logo}}" alt="Marine Logo" style="width:220px; max-width:220px;">
        </td>
      </tr>
      <tr>
        <td style="padding:32px 24px 16px;">
          <p style="margin:0 0 16px; font-size:16px;">Hello <strong>{{name}}</strong>,</p>
          <p style="margin:0 0 16px; font-size:16px;">Your supplier account has been created on First Mate.</p>
          <p style="margin:0 0 16px; font-size:16px;">Email: <strong>{{email}}</strong></p>
          <p style="margin:0 0 24px; font-size:16px;">Click the button below to create your password and activate your supplier account.</p>
          <div style="text-align:center; margin:32px 0 16px;">
            <a href="{{create_password_url}}" style="display:inline-block; background-color:#003760; color:#ffffff; text-decoration:none; padding:12px 24px; border-radius:6px; font-size:16px;">Create Password</a>
          </div>
          <div style="text-align:center; margin:16px 0 24px;">
            <a href="{{login_url}}" style="display:inline-block; background-color:#ffffff; color:#003760; text-decoration:none; padding:12px 24px; border-radius:6px; border:1px solid #003760; font-size:16px;">Supplier Login</a>
          </div>
        </td>
      </tr>
      <tr>
        <td style="padding:0 24px 32px;">
          <p style="margin:24px 0 0; font-size:16px;">Best regards,<br><strong>First Mate Team</strong></p>
        </td>
      </tr>
      <tr>
        <td style="background-color:#01365d; padding:24px; text-align:center;">
          <p style="margin:0 0 8px; color:#ffffff; font-size:14px;">Need More Help?</p>
          <a href="mailto:ahoy@firstmate.com.au" style="color:#ffffff; text-decoration:underline; font-size:14px;">We are here to help you out</a>
        </td>
      </tr>
    </table>
  </div>
</body>
</html>
