<!DOCTYPE HTML PUBLIC "-//W3C//DTD XHTML 1.0 Transitional //EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome to First Mate</title>

<style type="text/css">
a { text-decoration: none!important; color: #0000EE; }
p { font-size:15px; line-height:24px; font-family:'Helvetica', Arial, sans-serif; color: #000000; }
* { font-family: "Roboto", sans-serif; }
</style>
</head>

<body style="text-align: center; margin: 0; padding: 30px 0; background-color: #f2f4f6;">

<div style="text-align: center;">

<!-- LOGO -->
<table align="center" style="max-width: 600px; background-color: #ffffff;">
<tr>
<td style="padding-top: 40px;">
<img style="width: 276px;" alt="Logo" src="{{image_logo}}">
</td>
</tr>
</table>

<!-- CONTENT -->
<table align="center" style="max-width: 600px; width: 100%; background-color: #ffffff;">
<tr>
<td style="padding:30px 20px 15px; text-align:start;">
<span style="font-weight: 400;">
Welcome to First Mate
</span>
</td>
</tr>

<tr>
<td style="padding: 0 20px 40px;">
<h4 style="font-size:16px; margin-top:15px; text-align:start;">
Hello <b>{{name}}</b>,
</h4>

<h4 style="font-size:16px; margin-top:15px; text-align:start;">
<span style="font-weight:600; color:#01365d;">Email :</span>
<span>{{email}}</span>
</h4>

<h4 style="font-size:16px; margin-top:15px; text-align:start;">
<span style="font-weight:600; color:#01365d;">Password :</span>
<span>{{password}}</span>
</h4>

<h4 style="font-size:16px; margin-top:15px; text-align:start;">
Your account has been successfully created on First Mate.
</h4>

<h4 style="font-size:16px; margin-top:20px; text-align:start;">
👉 <a href="https://fmservicehub.com/technician/login" style="color:#01365d; font-weight:600;">
Login as Technician
</a>
</h4>

</td>
</tr>

<!-- FOOTER -->
<tr>
<td style="padding: 0 20px 40px;">
<div style="text-align:left;">
<p style="margin-bottom:0px; font-weight:500">Best regards,</p>
<h4 style="font-size:20px; margin-top:10px; font-weight:600;">
First Mate Team
</h4>
</div>
</td>
</tr>
</table>

<!-- HELP SECTION -->
<table align="center" style="max-width: 600px; width: 100%; background:#01365d">
<tr>
<td style="padding: 30px;">
<p style="color:#fff;">Need More Help?</p>
<a href="#" style="color:#fff; text-decoration: underline;">
We are here to help you out
</a>
</td>
</tr>
</table>

</div>
</body>
</html>
