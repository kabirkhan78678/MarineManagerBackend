generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  full_name     String
  phone_no      String?
  profile_image String?   @db.VarChar(255)
  role          String    @default("ADMIN")
  status        Int       @default(1)
  token         String?
  last_login_at DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model User {
  id                       Int                   @id @default(autoincrement())
  email                    String                @unique
  password                 String
  first_name               String
  last_name                String
  company_name             String                @db.LongText
  phone_no                 String
  fcm_token                String?
  act_token                String?
  token                    String?
  abn                      String?
  isVerified               Boolean               @default(false)
  company_logo             String?
  trade_license            String?
  accounting_software_used String?               @db.LongText
  about_us                 String?               @db.LongText
  service_region           String?               @db.LongText
  services_offered         String?               @db.LongText
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  ACC                      String                @default("")
  BSB                      String                @default("")
  stripeCustomerId         String?
  xero_access_token        String?               @db.LongText
  xero_refresh_token       String?
  xero_expiresAt           DateTime?
  xero_tenantId            String?
  xero_connected           Int                   @default(0)
  profile_image            String?               @db.VarChar(255)
  tooltipSeen              Boolean               @default(false)
  Boat                     Boat[]
  DockBooking              DockBooking[]
  InsuranceFile            InsuranceFile[]
  Invoice                  Invoice[]
  JobServiceSheet          JobServiceSheet[]
  PartInventory            PartInventory[]
  QuickLeads               QuickLeads[]
  Staff_Member             Staff_Member[]
  Subscription             Subscription?
  SubscriptionHistory      SubscriptionHistory[]
  Task                     Task[]
  UserSupplier             UserSupplier[]
}

model InsuranceFile {
  id       Int     @id @default(autoincrement())
  filename String?
  userId   Int
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "InsuranceFile_userId_fkey")
}

model Boat {
  id                   Int               @id @default(autoincrement())
  name                 String
  owners_name          String
  fileKey              String?
  avatar_url           String?
  rego                 String
  vin                  String
  make                 String
  model                String
  engine_no            String
  engine_make          String
  engine_model         String?
  length               String
  app_date             DateTime?
  book_from            DateTime?
  book_to              DateTime?
  email                String
  phone_no             String
  docking_date         DateTime?
  boat_type            String?
  userId               Int
  createdAt            DateTime          @default(now())
  updatedAt            DateTime?         @updatedAt
  inviteStatus         String?
  isBoathubRego        Boolean           @default(false)
  boat_weight_category WeightCategory?
  boat_length_category LengthCategory?
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  DockBooking          DockBooking[]
  Invoice              Invoice[]
  JobServiceSheet      JobServiceSheet[]
  Task                 Task[]

  @@index([userId], map: "Boat_userId_fkey")
}

model Staff_Member {
  id                         Int               @id @default(autoincrement())
  email                      String            @unique
  password                   String
  showPassword               String?
  token                      String?
  role                       String
  full_name                  String
  home_address               String            @db.LongText
  userId                     Int
  status                     Int               @default(1)
  phone_no                   String
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  system_deactivation_status Int               @default(1)
  hourly_rate                Float             @default(0)
  JobServiceSheet            JobServiceSheet[]
  Notification               Notification[]
  user                       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  Task                       Task[]
  TaskPhoto                  TaskPhoto[]

  @@index([userId], map: "Staff_Member_userId_fkey")
}

model Supplier {
  id                       Int                     @id @default(autoincrement())
  email                    String                  @unique
  password                 String?
  first_name               String?
  last_name                String?
  company_name             String?                 @db.LongText
  company_description      String?                 @db.LongText
  status                   Int                     @default(1)
  phone_no                 String?
  city                     String?
  company_logo             String?
  abn                      String?
  token                    String?
  trade_license            String?
  accounting_software_used String?                 @db.LongText
  about_us                 String?                 @db.LongText
  service_region           String?                 @db.LongText
  services_offered         String?                 @db.LongText
  complete_profile_status  Int                     @default(0)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  JobServiceSheet          JobServiceSheet[]
  SupplierInsuranceFile    SupplierInsuranceFile[]
  Task                     Task[]
  TaskPhoto                TaskPhoto[]
  TaskSupplierOffer        TaskSupplierOffer[]
  UserSupplier             UserSupplier[]
}

model SupplierInsuranceFile {
  id         Int      @id @default(autoincrement())
  filename   String?
  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId], map: "SupplierInsuranceFile_supplierId_fkey")
}

model Task {
  id                   Int                     @id @default(autoincrement())
  description          String?                 @db.LongText
  time_alloted         String
  quoted_value         String
  boatId               Int
  assignStaffId        Int?
  status               Int                     @default(0)
  supplierId           Int?
  userId               Int
  assign_to            AssignTo
  date_scheduled_from  DateTime
  date_scheduled_to    DateTime
  taskInfo             String?                 @db.LongText
  supplierNotes        String?                 @db.LongText
  futureWatchList      String?                 @db.LongText
  recommendedDueDate   DateTime?
  avatar_url           String?
  isRecurring          Int                     @default(0)
  completed_at         DateTime?
  contacted_status     Int                     @default(0)
  jobNumber            String?
  invoiceId            Int?
  job_end_time         DateTime?
  job_start_time       DateTime?
  paused_durations     String?                 @db.LongText
  scheduled_start_time DateTime?
  timer_status         String?                 @default("PENDING")
  total_active_minutes Int?                    @default(0)
  ownerApprovalStatus  OwnerApprovalStatus     @default(PENDING)
  performanceStatus    Task_performanceStatus?
  TaskEfficiency       Task_TaskEfficiency?
  createdAt            DateTime                @default(now()) @db.DateTime(0)
  JobServiceSheet      JobServiceSheet[]
  JobTimerLog          JobTimerLog[]
  Notification         Notification[]
  staff                Staff_Member?           @relation(fields: [assignStaffId], references: [id], onDelete: Cascade)
  boat                 Boat                    @relation(fields: [boatId], references: [id], onDelete: Cascade)
  invoice              Invoice?                @relation("InvoiceTasks", fields: [invoiceId], references: [id])
  supplier             Supplier?               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  TaskPhoto            TaskPhoto[]
  TaskServices         TaskService[]
  TaskSupplierOffer    TaskSupplierOffer[]

  @@index([assignStaffId], map: "Task_assignStaffId_fkey")
  @@index([boatId], map: "Task_boatId_fkey")
  @@index([invoiceId], map: "Task_invoiceId_fkey")
  @@index([supplierId], map: "Task_supplierId_fkey")
  @@index([userId], map: "Task_userId_fkey")
}

model PartInventory {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  original_cost   Float     @db.Float
  boat_owner_cost Float     @db.Float
  stock_quantity  Int?      @default(0)
  low_stock_alert Int?      @default(10)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @updatedAt @db.DateTime(0)
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_part_inventory_user")

  @@index([userId], map: "fk_part_inventory_user")
}

model QuickLeads {
  id                    Int      @id @default(autoincrement())
  client_name           String
  client_contact_number String
  status                Int      @default(0)
  userId                Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())
  notes                 String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "QuickLeads_userId_fkey")
}

model DockBooking {
  id        Int      @id @default(autoincrement())
  dockId    Int
  boatId    Int?
  book_from DateTime
  book_to   DateTime
  createdAt DateTime @default(now())
  userId    Int
  boat      Boat?    @relation(fields: [boatId], references: [id], onDelete: Cascade)
  dock      dock     @relation(fields: [dockId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boatId], map: "DockBooking_boatId_fkey")
  @@index([dockId], map: "DockBooking_dockId_fkey")
  @@index([userId], map: "DockBooking_userId_fkey")
}

model JobServiceSheet {
  id                 Int           @id @default(autoincrement())
  date               DateTime
  jobNumber          String?
  personAttending    String?
  customerName       String?
  mobile             String?
  workToBeCarriedOut String?       @db.LongText
  workCarriedOut     String?       @db.LongText
  cdsSignature       String?       @db.LongText
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  taskId             Int?
  staffId            Int?
  supplierId         Int?
  boatId             Int           @default(1)
  documentLink       String?       @unique
  userId             Int           @default(1)
  boat               Boat          @relation(fields: [boatId], references: [id], onDelete: Cascade)
  staff              Staff_Member? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  supplier           Supplier?     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  task               Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Material           Material[]

  @@index([boatId], map: "JobServiceSheet_boatId_fkey")
  @@index([staffId], map: "JobServiceSheet_staffId_fkey")
  @@index([supplierId], map: "JobServiceSheet_supplierId_fkey")
  @@index([taskId], map: "JobServiceSheet_taskId_fkey")
  @@index([userId], map: "JobServiceSheet_userId_fkey")
}

model TaskPhoto {
  id         Int           @id @default(autoincrement())
  url        String        @db.LongText
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  staffId    Int?
  supplierId Int?
  taskId     Int
  staff      Staff_Member? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  supplier   Supplier?     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  task       Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([staffId], map: "TaskPhoto_staffId_fkey")
  @@index([supplierId], map: "TaskPhoto_supplierId_fkey")
  @@index([taskId], map: "TaskPhoto_taskId_fkey")
}

model Notification {
  id        Int           @id @default(autoincrement())
  byStaffId Int?
  toUserId  Int
  taskId    Int
  isRead    Boolean       @default(false)
  content   String?
  type      String?
  data      String?       @db.LongText
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  byStaff   Staff_Member? @relation(fields: [byStaffId], references: [id], onDelete: Cascade)
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([byStaffId], map: "Notification_byStaffId_fkey")
  @@index([taskId], map: "Notification_taskId_fkey")
}

model ServicePreset {
  id                Int           @id @default(autoincrement())
  serviceTitle      String
  serviceCost       Float
  boatLength        String?
  boatHeight        String?
  materialCost      Float?
  labourAdjustments Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  TaskServices      TaskService[]
}

model TaskService {
  id           Int           @id @default(autoincrement())
  taskId       Int
  serviceId    Int
  serviceName  String
  servicePrice Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  service      ServicePreset @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([taskId])
}

model UserSupplier {
  id         Int      @id @default(autoincrement())
  userId     Int
  supplierId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  name       String?
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, supplierId])
  @@index([supplierId], map: "UserSupplier_supplierId_fkey")
}

model Material {
  id                Int             @id @default(autoincrement())
  materialName      String?
  unitsUsed         Float
  pricePerUnit      Float?
  totalPrice        Float
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  jobServiceSheetId Int
  jobServiceSheet   JobServiceSheet @relation(fields: [jobServiceSheetId], references: [id], onDelete: Cascade)

  @@index([jobServiceSheetId], map: "Material_jobServiceSheetId_fkey")
}

model Invoice {
  id                  Int      @id @default(autoincrement())
  invoiceNumber       String?  @unique
  boatId              Int
  userId              Int
  pleasePayByDate     DateTime
  status              Int      @default(0)
  totalAmount         Float    @default(0)
  totalAmountAfterTax Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  documentLink        String?  @unique
  boat                Boat     @relation(fields: [boatId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks               Task[]   @relation("InvoiceTasks")

  @@index([boatId], map: "Invoice_boatId_fkey")
  @@index([userId], map: "Invoice_userId_fkey")
}

model Plan {
  id                  Int                   @id @default(autoincrement())
  name                String?
  price               Float
  billingCycle        String
  maxStaffUsers       Int
  stripePriceId       String?               @unique
  Subscription        Subscription[]
  SubscriptionHistory SubscriptionHistory[]
}

model Subscription {
  id                   Int       @id @default(autoincrement())
  planId               Int
  userId               Int       @unique
  created_at           DateTime  @default(now())
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?   @unique
  renewed_at           DateTime?
  sub_status           Int
  start_date           DateTime
  canceled_at          DateTime?
  trial_end_date       DateTime?
  failed_at            DateTime?
  plan                 Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planId], map: "Subscription_planId_fkey")
}

model SubscriptionHistory {
  id                   Int       @id @default(autoincrement())
  planId               Int
  userId               Int
  created_at           DateTime  @default(now())
  stripeSubscriptionId String?
  stripeCustomerId     String?
  renewed_at           DateTime?
  sub_status           Int
  start_date           DateTime
  canceled_at          DateTime?
  trial_end_date       DateTime?
  failed_at            DateTime?
  plan                 Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planId], map: "SubscriptionHistory_planId_fkey")
  @@index([userId], map: "SubscriptionHistory_userId_fkey")
}

model JobTimerLog {
  id        Int       @id @default(autoincrement())
  taskId    Int
  type      TimerType
  timestamp DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "JobTimerLog_taskId_fkey")
}

model TaskSupplierOffer {
  id            Int             @id @default(autoincrement())
  taskId        Int
  supplierId    Int
  status        AcceptaneStatus
  responded_at  DateTime?
  offered_price Float?
  supplier      Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  task          Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, supplierId])
  @@index([supplierId], map: "TaskSupplierOffer_supplierId_fkey")
}

model admin_user_count_snapshots {
  id               Int      @id @default(autoincrement())
  snapshot_date    DateTime @unique @db.Date
  total_user       Int      @default(0)
  total_client     Int      @default(0)
  total_technician Int      @default(0)
  total_supplier   Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
}

model dock {
  id                   Int                        @id @default(autoincrement())
  name                 String
  email                String?
  phone_no             String?
  userId               Int
  booking_cost         String?
  booking_cost_per_day String?
  address              String
  created_at           DateTime?                  @default(now()) @db.Timestamp(0)
  dock_capacity        Int                        @default(1)
  dock_weight_category dock_dock_weight_category?
  dock_length_category dock_dock_length_category?
  DockBooking          DockBooking[]

  @@index([userId], map: "Dock_userId_fkey")
}

enum WeightCategory {
  UP_TO_500_KG
  UP_TO_1_TON
  UP_TO_2_TONS
  UP_TO_5_TONS
  UP_TO_10_TONS
  OVER_10_TONS
}

enum LengthCategory {
  UP_TO_5_FT
  FIVE_TO_TEN_FT      @map("5_TO_10_FT")
  TEN_TO_TWENTY_FT    @map("10_TO_20_FT")
  TWENTY_TO_THIRTY_FT @map("20_TO_30_FT")
  THIRTY_TO_FORTY_FT  @map("30_TO_40_FT")
  FORTY_PLUS_FT       @map("40_PLUS_FT")
}

enum AssignTo {
  STAFF
  OUTSOURCED
}

enum OwnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimerType {
  START
  PAUSE
  RESUME
  COMPLETE
}

enum AcceptaneStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum dock_dock_weight_category {
  UP_TO_500_KG
  UP_TO_1_TON
  UP_TO_2_TONS
  UP_TO_5_TONS
  UP_TO_10_TONS
  OVER_10_TONS
}

enum dock_dock_length_category {
  UP_TO_5_FT
  TO_10_FT   @map("5_TO_10_FT")
  TO_20_FT   @map("10_TO_20_FT")
  TO_30_FT   @map("20_TO_30_FT")
  TO_40_FT   @map("30_TO_40_FT")
  PLUS_FT    @map("40_PLUS_FT")
}

enum Task_performanceStatus {
  EARLY
  ON_TIME
  LATE
  EMPTY_ENUM_VALUE @map("")
}

enum Task_TaskEfficiency {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}
